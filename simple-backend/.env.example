# =====================================================
# HACK PROFILE - Video + Avatar + Thymia + Shen
# =====================================================

# Agora credentials
HACK_APP_ID=<your-agora-app-id>
HACK_APP_CERTIFICATE=<your-agora-app-certificate>
HACK_ENABLE_MLLM=false
HACK_THYMIA_API_KEY=<your-thymia-api-key>

# LLM — custom LLM server (remote, with Thymia + Shen modules)
HACK_LLM_URL=<your-custom-llm-url>/chat/completions
HACK_LLM_VENDOR=custom
HACK_LLM_STYLE=openai
HACK_LLM_MODEL=gpt-4o-mini
HACK_LLM_API_KEY=<your-openai-api-key>

# TTS
HACK_TTS_VENDOR=elevenlabs
HACK_TTS_KEY=<your-elevenlabs-key>
HACK_TTS_VOICE_ID=<your-elevenlabs-voice-id>
HACK_ELEVENLABS_MODEL=eleven_flash_v2_5
HACK_TTS_SAMPLE_RATE=24000
HACK_ELEVENLABS_STABILITY=0.5

# ASR
HACK_ASR_VENDOR=deepgram
HACK_ASR_LANGUAGE=en-US
HACK_DEEPGRAM_KEY=<your-deepgram-key>
HACK_DEEPGRAM_MODEL=nova-3
HACK_DEEPGRAM_LANGUAGE=en

# Avatar
HACK_ENABLE_AIVAD=true
HACK_AVATAR_VENDOR=anam
HACK_AVATAR_API_KEY=<your-anam-api-key>
HACK_AVATAR_ID=<your-anam-avatar-id>

# Session
HACK_VAD_SILENCE_DURATION_MS=300
HACK_IDLE_TIMEOUT=120
HACK_MAX_HISTORY=32
HACK_ENABLE_CURL_DUMP=true

# Greeting + Prompt
HACK_DEFAULT_GREETING=Hi there! I'm Fergus. I'd love to have a quick chat and learn a bit about how you're doing. What's your name?
HACK_DEFAULT_PROMPT=You are a compassionate wellness assistant. Ask open-ended questions about how the user is feeling. Keep responses warm and under 30 words.
HACK_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong

ENABLE_CURL_DUMP=true
